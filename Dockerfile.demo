FROM python:3.13-slim

WORKDIR /app

ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app/backend
ENV HOST=0.0.0.0
ENV PORT=8000

COPY backend ./backend
COPY static ./static

EXPOSE 8000

# Legacy single-container demo entrypoint. The formal app uses backend/app/main.py.
CMD ["python", "backend/dev_server.py"]
